// SPDX-License-Identifier: GPL-2.0
// Anemometer Device Tree Overlay for Raspberry Pi
// Example: GPIO 26 with pull-up enabled
//
// Usage:
// 1. Copy to /boot/overlays/anemometer-gpio26.dts
// 2. Compile: sudo dtc -I dts -O dtb -o /boot/overlays/anemometer-gpio26.dtbo /boot/overlays/anemometer-gpio26.dts
// 3. Enable: Add to /boot/config.txt: dtoverlay=anemometer-gpio26
// 4. Reboot

/dts-v1/;
/plugin/;

/ {
	compatible = "brcm,bcm2835";

	// Fragment to enable GPIO 26
	fragment@0 {
		target = <&gpio>;
		__overlay__ {
			anemometer_pins: anemometer_pins {
				brcm,pins = <26>;           // GPIO 26 (Physical Pin 37)
				brcm,function = <0>;         // GPIO input (0 = input, 1 = output)
				brcm,pull = <2>;             // Pull-up (0 = none, 1 = down, 2 = up)
			};
		};
	};

	// Fragment to create anemometer node
	fragment@1 {
		target-path = "/";
		__overlay__ {
			anemometer {
				compatible = "generic,anemometer";
				status = "okay";
				pinctrl-names = "default";
				pinctrl-0 = <&anemometer_pins>;

				// Single sensor on GPIO 26
				sensor@0 {
					label = "wind";
					gpios = <&gpio 26 GPIO_ACTIVE_HIGH>;
					
					// Averaging window: 5 seconds
					window-size = <5>;
					
					// Update interval: 1000ms (1 second)
					update-interval = <1000>;
					
					// Calibration: 0.1 m/s per Hz (default)
					slope = <100>;
					slope-div = <1000>;
					
					// Zero offset
					offset = <0>;
					
					// Pull-up is handled by pinctrl above, but you can also specify:
					pull = "up";
					
					// Optional: Enable debounce (hardware-dependent)
					// debounce-us = <1000>;  // 1ms debounce
				};
			};
		};
	};
};
